//@version=5
indicator("Layer 8 NQ Confluence Engine v0.4", overlay=true, max_lines_count=500, max_labels_count=500)

// -----------------------------------------------------------------------------
// Layer 8 NQ Confluence Engine v0.4
// Original TradingView indicator prototype.
// This does not copy or reverse-engineer any proprietary QuantVue code.
// Purpose: dashboard-first decision support for manual NQ/MNQ trading.
// -----------------------------------------------------------------------------

// =============================================================================
// Inputs
// =============================================================================

groupLevels = "Levels"
showPrevDay = input.bool(true, "Show Prior Day High/Low", group=groupLevels)
showOvernight = input.bool(true, "Show Overnight High/Low", group=groupLevels)
show8am = input.bool(true, "Show 8am Candle Zone", group=groupLevels)
showOR3 = input.bool(true, "Show 3-Minute Opening Range", group=groupLevels)
showOR15 = input.bool(true, "Show 15-Minute Opening Range", group=groupLevels)

sessionTZ = input.string("America/New_York", "Session Timezone", group=groupLevels)
overnightSession = input.session("1800-0929", "Overnight Session", group=groupLevels)
eightAmSession = input.session("0800-0801", "8am Capture Window", group=groupLevels)
or3Session = input.session("0930-0933", "3-Minute OR Window", group=groupLevels)
or15Session = input.session("0930-0945", "15-Minute OR Window", group=groupLevels)

groupTrend = "Trend"
showTrendCloud = input.bool(true, "Show EMA Trend Cloud", group=groupTrend)
fastEmaLen = input.int(21, "Fast EMA", minval=1, group=groupTrend)
slowEmaLen = input.int(55, "Slow EMA", minval=1, group=groupTrend)
trendNeutralPoints = input.float(0.0, "Neutral Buffer Points", minval=0.0, group=groupTrend)

groupMomentum = "Momentum"
rsiLen = input.int(14, "RSI Length", minval=1, group=groupMomentum)
rsiBull = input.float(55.0, "RSI Bull Threshold", group=groupMomentum)
rsiBear = input.float(45.0, "RSI Bear Threshold", group=groupMomentum)

groupBands = "Volatility Bands"
showAtrBands = input.bool(true, "Show ATR Bands", group=groupBands)
atrLen = input.int(14, "ATR Length", minval=1, group=groupBands)
atrMult = input.float(2.0, "ATR Multiplier", minval=0.1, step=0.1, group=groupBands)
bandBasisLen = input.int(34, "Band Basis EMA", minval=1, group=groupBands)

groupStructure = "Structure"
useBasicStructure = input.bool(true, "Use Basic Swing Structure", group=groupStructure)
swingLen = input.int(8, "Swing Length", minval=1, group=groupStructure)
showSweepMarkers = input.bool(false, "Show Sweep Markers", group=groupStructure)
sweepCooldownBars = input.int(20, "Sweep Marker Cooldown Bars", minval=0, group=groupStructure)

groupDisplay = "Display"
displayMode = input.string("Dashboard Only", "Display Mode", options=["Dashboard Only", "Minimal Markers", "Full Labels"], group=groupDisplay)
showDashboard = input.bool(true, "Show Dashboard", group=groupDisplay)
shadeSignalBars = input.bool(false, "Shade Signal Bars", group=groupDisplay)

groupSignals = "Signal Rules"
labelMode = input.string("Transition Only", "Signal Mode", options=["Transition Only", "Cooldown", "Every Bar"], group=groupSignals)
signalCooldownBars = input.int(35, "Signal Cooldown Bars", minval=0, group=groupSignals)
minScore = input.int(8, "Minimum Alert Score", minval=1, maxval=10, group=groupSignals)
levelProximity = input.float(15.0, "Level Proximity Points", minval=0.25, step=0.25, group=groupSignals)
requireAlignedLocation = input.bool(true, "Require Location Aligned With Trend", group=groupSignals)
requireMomentumForSignal = input.bool(true, "Require Momentum For Signal", group=groupSignals)
requireStructureOrRetest = input.bool(true, "Require Structure/Sweep/OR Retest", group=groupSignals)
requireTrendForSignal = input.bool(true, "Require Trend Alignment For Signal", group=groupSignals)

// =============================================================================
// Helpers
// =============================================================================

inSession(sess) =>
    not na(time(timeframe.period, sess, sessionTZ))

nearLevel(price, level, distance) =>
    not na(level) and math.abs(price - level) <= distance

isIntraday = timeframe.isintraday
newDay = ta.change(time("D"))

// =============================================================================
// Prior day levels
// =============================================================================

prevDayHigh = request.security(syminfo.tickerid, "D", high[1], barmerge.gaps_off, barmerge.lookahead_on)
prevDayLow = request.security(syminfo.tickerid, "D", low[1], barmerge.gaps_off, barmerge.lookahead_on)

plot(showPrevDay ? prevDayHigh : na, "Prior Day High", color=color.new(color.white, 0), linewidth=1, style=plot.style_linebr)
plot(showPrevDay ? prevDayLow : na, "Prior Day Low", color=color.new(color.gray, 0), linewidth=1, style=plot.style_linebr)

// =============================================================================
// Overnight levels
// =============================================================================

isON = isIntraday and inSession(overnightSession)

var float onHigh = na
var float onLow = na

if newDay
    onHigh := na
    onLow := na

if isON
    onHigh := na(onHigh) ? high : math.max(onHigh, high)
    onLow := na(onLow) ? low : math.min(onLow, low)

plot(showOvernight and isIntraday ? onHigh : na, "Overnight High", color=color.new(color.yellow, 0), linewidth=1, style=plot.style_linebr)
plot(showOvernight and isIntraday ? onLow : na, "Overnight Low", color=color.new(color.orange, 0), linewidth=1, style=plot.style_linebr)

// =============================================================================
// 8am zone
// =============================================================================

is8am = isIntraday and inSession(eightAmSession)
var float eightHigh = na
var float eightLow = na
var float eightOpen = na
var float eightClose = na

if newDay
    eightHigh := na
    eightLow := na
    eightOpen := na
    eightClose := na

if is8am and not is8am[1]
    eightHigh := high
    eightLow := low
    eightOpen := open
    eightClose := close
else if is8am
    eightHigh := math.max(nz(eightHigh, high), high)
    eightLow := math.min(nz(eightLow, low), low)
    eightClose := close

plot(show8am and isIntraday ? eightHigh : na, "8am High", color=color.new(color.aqua, 0), linewidth=1, style=plot.style_linebr)
plot(show8am and isIntraday ? eightLow : na, "8am Low", color=color.new(color.aqua, 0), linewidth=1, style=plot.style_linebr)
plot(show8am and isIntraday ? math.max(eightOpen, eightClose) : na, "8am Body High", color=color.new(color.aqua, 65), linewidth=1, style=plot.style_linebr)
plot(show8am and isIntraday ? math.min(eightOpen, eightClose) : na, "8am Body Low", color=color.new(color.aqua, 65), linewidth=1, style=plot.style_linebr)

// =============================================================================
// Opening ranges
// =============================================================================

isOR3 = isIntraday and inSession(or3Session)
isOR15 = isIntraday and inSession(or15Session)

var float or3High = na
var float or3Low = na
var float or15High = na
var float or15Low = na

if newDay
    or3High := na
    or3Low := na
    or15High := na
    or15Low := na

if isOR3
    or3High := na(or3High) ? high : math.max(or3High, high)
    or3Low := na(or3Low) ? low : math.min(or3Low, low)

if isOR15
    or15High := na(or15High) ? high : math.max(or15High, high)
    or15Low := na(or15Low) ? low : math.min(or15Low, low)

plot(showOR3 and isIntraday ? or3High : na, "3m OR High", color=color.new(color.lime, 0), linewidth=1, style=plot.style_linebr)
plot(showOR3 and isIntraday ? or3Low : na, "3m OR Low", color=color.new(color.red, 0), linewidth=1, style=plot.style_linebr)
plot(showOR15 and isIntraday ? or15High : na, "15m OR High", color=color.new(color.green, 0), linewidth=2, style=plot.style_linebr)
plot(showOR15 and isIntraday ? or15Low : na, "15m OR Low", color=color.new(color.maroon, 0), linewidth=2, style=plot.style_linebr)

// =============================================================================
// Trend cloud
// =============================================================================

emaFast = ta.ema(close, fastEmaLen)
emaSlow = ta.ema(close, slowEmaLen)
trendBull = emaFast > emaSlow + trendNeutralPoints
trendBear = emaFast < emaSlow - trendNeutralPoints
trendText = trendBull ? "Bull" : trendBear ? "Bear" : "Neutral"

pFast = plot(showTrendCloud ? emaFast : na, "Fast EMA", color=color.new(color.teal, 0), linewidth=1)
pSlow = plot(showTrendCloud ? emaSlow : na, "Slow EMA", color=color.new(color.blue, 0), linewidth=1)
fill(pFast, pSlow, color=trendBull ? color.new(color.teal, 85) : trendBear ? color.new(color.red, 85) : color.new(color.gray, 90), title="Trend Cloud")

// =============================================================================
// Momentum and ATR bands
// =============================================================================

rsi = ta.rsi(close, rsiLen)
momentumBull = rsi >= rsiBull
momentumBear = rsi <= rsiBear
momentumText = momentumBull ? "Bull" : momentumBear ? "Bear" : "Neutral"

atr = ta.atr(atrLen)
basis = ta.ema(close, bandBasisLen)
upperBand = basis + atr * atrMult
lowerBand = basis - atr * atrMult

plot(showAtrBands ? basis : na, "ATR Band Basis", color=color.new(color.gray, 30), linewidth=1)
plot(showAtrBands ? upperBand : na, "ATR Upper Band", color=color.new(color.gray, 60), linewidth=1)
plot(showAtrBands ? lowerBand : na, "ATR Lower Band", color=color.new(color.gray, 60), linewidth=1)

nearUpperBand = nearLevel(close, upperBand, levelProximity)
nearLowerBand = nearLevel(close, lowerBand, levelProximity)

// =============================================================================
// Structure and sweeps
// =============================================================================

swingHigh = ta.pivothigh(high, swingLen, swingLen)
swingLow = ta.pivotlow(low, swingLen, swingLen)

var float lastSwingHigh = na
var float lastSwingLow = na

if not na(swingHigh)
    lastSwingHigh := swingHigh

if not na(swingLow)
    lastSwingLow := swingLow

bosBull = useBasicStructure and not na(lastSwingHigh) and close > lastSwingHigh
bosBear = useBasicStructure and not na(lastSwingLow) and close < lastSwingLow
rawSweepLowReclaim = useBasicStructure and not na(lastSwingLow) and low < lastSwingLow and close > lastSwingLow
rawSweepHighReject = useBasicStructure and not na(lastSwingHigh) and high > lastSwingHigh and close < lastSwingHigh

var int lastBullSweepBar = na
var int lastBearSweepBar = na
bullSweepOk = rawSweepLowReclaim and (na(lastBullSweepBar) or bar_index - lastBullSweepBar >= sweepCooldownBars)
bearSweepOk = rawSweepHighReject and (na(lastBearSweepBar) or bar_index - lastBearSweepBar >= sweepCooldownBars)

if bullSweepOk
    lastBullSweepBar := bar_index
if bearSweepOk
    lastBearSweepBar := bar_index

plotshape(showSweepMarkers and bullSweepOk, title="Sell-side Sweep/Reclaim", style=shape.triangleup, location=location.belowbar, color=color.new(color.lime, 0), size=size.tiny, text="")
plotshape(showSweepMarkers and bearSweepOk, title="Buy-side Sweep/Reject", style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 0), size=size.tiny, text="")

// =============================================================================
// Location and retest logic
// =============================================================================

supportLocation = nearLevel(close, prevDayLow, levelProximity) or nearLevel(close, onLow, levelProximity) or nearLevel(close, eightLow, levelProximity) or nearLevel(close, or3High, levelProximity) or nearLevel(close, or15High, levelProximity) or nearLowerBand
resistanceLocation = nearLevel(close, prevDayHigh, levelProximity) or nearLevel(close, onHigh, levelProximity) or nearLevel(close, eightHigh, levelProximity) or nearLevel(close, or3Low, levelProximity) or nearLevel(close, or15Low, levelProximity) or nearUpperBand

or15LongRetest = isIntraday and showOR15 and not na(or15High) and close > or15High and nearLevel(low, or15High, levelProximity)
or15ShortRetest = isIntraday and showOR15 and not na(or15Low) and close < or15Low and nearLevel(high, or15Low, levelProximity)
or3LongRetest = isIntraday and showOR3 and not na(or3High) and close > or3High and nearLevel(low, or3High, levelProximity)
or3ShortRetest = isIntraday and showOR3 and not na(or3Low) and close < or3Low and nearLevel(high, or3Low, levelProximity)

longLocation = supportLocation or or15LongRetest or or3LongRetest
shortLocation = resistanceLocation or or15ShortRetest or or3ShortRetest
alignedLongLocation = requireAlignedLocation ? longLocation : (longLocation or shortLocation)
alignedShortLocation = requireAlignedLocation ? shortLocation : (shortLocation or longLocation)
locationText = longLocation and shortLocation ? "Mixed" : longLocation ? "Support/Long" : shortLocation ? "Resistance/Short" : "None"

// =============================================================================
// Confluence scoring
// =============================================================================

longStructure = bosBull or rawSweepLowReclaim or or15LongRetest or or3LongRetest
shortStructure = bosBear or rawSweepHighReject or or15ShortRetest or or3ShortRetest
longHasRoom = not nearLevel(close, prevDayHigh, levelProximity) and not nearLevel(close, onHigh, levelProximity) and not nearUpperBand
shortHasRoom = not nearLevel(close, prevDayLow, levelProximity) and not nearLevel(close, onLow, levelProximity) and not nearLowerBand

longScore = 0
shortScore = 0
longScore += alignedLongLocation ? 2 : 0
shortScore += alignedShortLocation ? 2 : 0
longScore += trendBull ? 2 : 0
shortScore += trendBear ? 2 : 0
longScore += momentumBull ? 2 : 0
shortScore += momentumBear ? 2 : 0
longScore += longStructure ? 2 : 0
shortScore += shortStructure ? 2 : 0
longScore += longHasRoom ? 2 : 0
shortScore += shortHasRoom ? 2 : 0

longGate = (not requireTrendForSignal or trendBull) and (not requireMomentumForSignal or momentumBull) and (not requireStructureOrRetest or longStructure)
shortGate = (not requireTrendForSignal or trendBear) and (not requireMomentumForSignal or momentumBear) and (not requireStructureOrRetest or shortStructure)
rawLongWatch = longGate and longScore >= minScore and longScore > shortScore
rawShortWatch = shortGate and shortScore >= minScore and shortScore > longScore

// =============================================================================
// Signal gating
// =============================================================================

var int lastLongSignalBar = na
var int lastShortSignalBar = na
longTransition = rawLongWatch and not rawLongWatch[1]
shortTransition = rawShortWatch and not rawShortWatch[1]
longCooldownOk = rawLongWatch and (na(lastLongSignalBar) or bar_index - lastLongSignalBar >= signalCooldownBars)
shortCooldownOk = rawShortWatch and (na(lastShortSignalBar) or bar_index - lastShortSignalBar >= signalCooldownBars)
longSignal = labelMode == "Every Bar" ? rawLongWatch : labelMode == "Cooldown" ? longCooldownOk : longTransition
shortSignal = labelMode == "Every Bar" ? rawShortWatch : labelMode == "Cooldown" ? shortCooldownOk : shortTransition

if longSignal
    lastLongSignalBar := bar_index
if shortSignal
    lastShortSignalBar := bar_index

// =============================================================================
// Visual output
// =============================================================================

showMinimalMarkers = displayMode == "Minimal Markers"
showFullLabels = displayMode == "Full Labels"

plotshape(showMinimalMarkers and longSignal, title="Long Watch Marker", style=shape.triangleup, location=location.belowbar, color=color.new(color.lime, 0), size=size.small, text="")
plotshape(showMinimalMarkers and shortSignal, title="Short Watch Marker", style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 0), size=size.small, text="")
plotshape(showFullLabels and longSignal, title="Long Watch Label", style=shape.labelup, location=location.belowbar, color=color.new(color.lime, 0), textcolor=color.black, text="Long\nWatch")
plotshape(showFullLabels and shortSignal, title="Short Watch Label", style=shape.labeldown, location=location.abovebar, color=color.new(color.red, 0), textcolor=color.white, text="Short\nWatch")
barcolor(shadeSignalBars and rawLongWatch ? color.new(color.lime, 65) : shadeSignalBars and rawShortWatch ? color.new(color.red, 65) : na)

// =============================================================================
// Alerts
// =============================================================================

alertcondition(longSignal, title="Layer 8 Long Watch", message="Layer 8 NQ Confluence Engine: Long Watch. Confirm stop, target, and prop-firm risk before manual entry.")
alertcondition(shortSignal, title="Layer 8 Short Watch", message="Layer 8 NQ Confluence Engine: Short Watch. Confirm stop, target, and prop-firm risk before manual entry.")
alertcondition(or15LongRetest, title="15m OR Long Retest", message="15-minute opening range high retest detected. Confirm confluence before entry.")
alertcondition(or15ShortRetest, title="15m OR Short Retest", message="15-minute opening range low retest detected. Confirm confluence before entry.")
alertcondition(or3LongRetest, title="3m OR Long Retest", message="3-minute opening range high retest detected. Confirm confluence before entry.")
alertcondition(or3ShortRetest, title="3m OR Short Retest", message="3-minute opening range low retest detected. Confirm confluence before entry.")
alertcondition(bullSweepOk, title="Sell-side Sweep Reclaim", message="Sell-side liquidity sweep and reclaim detected.")
alertcondition(bearSweepOk, title="Buy-side Sweep Reject", message="Buy-side liquidity sweep and rejection detected.")

// =============================================================================
// Dashboard
// =============================================================================

var table dash = table.new(position.top_right, 2, 8, border_width=1)

if showDashboard and barstate.islast
    table.cell(dash, 0, 0, "Layer 8 NQ Engine", text_color=color.white, bgcolor=color.new(color.black, 0))
    table.cell(dash, 1, 0, "v0.4", text_color=color.white, bgcolor=color.new(color.black, 0))
    table.cell(dash, 0, 1, "Long Score", text_color=color.white, bgcolor=color.new(color.black, 15))
    table.cell(dash, 1, 1, str.tostring(longScore) + "/10", text_color=longScore >= minScore ? color.lime : color.white, bgcolor=color.new(color.black, 15))
    table.cell(dash, 0, 2, "Short Score", text_color=color.white, bgcolor=color.new(color.black, 15))
    table.cell(dash, 1, 2, str.tostring(shortScore) + "/10", text_color=shortScore >= minScore ? color.red : color.white, bgcolor=color.new(color.black, 15))
    table.cell(dash, 0, 3, "Trend", text_color=color.white, bgcolor=color.new(color.black, 15))
    table.cell(dash, 1, 3, trendText, text_color=trendBull ? color.lime : trendBear ? color.red : color.gray, bgcolor=color.new(color.black, 15))
    table.cell(dash, 0, 4, "Momentum", text_color=color.white, bgcolor=color.new(color.black, 15))
    table.cell(dash, 1, 4, momentumText, text_color=momentumBull ? color.lime : momentumBear ? color.red : color.gray, bgcolor=color.new(color.black, 15))
    table.cell(dash, 0, 5, "Location", text_color=color.white, bgcolor=color.new(color.black, 15))
    table.cell(dash, 1, 5, locationText, text_color=longLocation and not shortLocation ? color.lime : shortLocation and not longLocation ? color.red : longLocation and shortLocation ? color.yellow : color.gray, bgcolor=color.new(color.black, 15))
    table.cell(dash, 0, 6, "Structure", text_color=color.white, bgcolor=color.new(color.black, 15))
    table.cell(dash, 1, 6, longStructure ? "Bull" : shortStructure ? "Bear" : "Neutral", text_color=longStructure ? color.lime : shortStructure ? color.red : color.gray, bgcolor=color.new(color.black, 15))
    table.cell(dash, 0, 7, "State", text_color=color.white, bgcolor=color.new(color.black, 15))
    table.cell(dash, 1, 7, rawLongWatch ? "LONG WATCH" : rawShortWatch ? "SHORT WATCH" : "WAIT", text_color=rawLongWatch ? color.lime : rawShortWatch ? color.red : color.gray, bgcolor=color.new(color.black, 15))
